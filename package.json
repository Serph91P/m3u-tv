{
  "name": "m3u-tv",
  "version": "0.0.1",
  "description": "Legacy React Native/Expo reference for the Flutter m3u-tv client",
  "author": {
    "name": "sparkison",
    "email": "sparkison@users.noreply.github.com"
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "legacy:rn:start": "EXPO_TV=1 expo start",
    "legacy:rn:android": "EXPO_TV=1 expo run:android",
    "legacy:rn:bundle-android": "cd android && ./gradlew bundleRelease && cd ..",
    "legacy:rn:build-apk": "cd android && ./gradlew assembleRelease && cd ..",
    "legacy:rn:ios": "EXPO_TV=1 expo run:ios",
    "legacy:rn:web": "expo start --web",
    "legacy:rn:build-web": "expo export --platform web",
    "legacy:rn:mobile-android": "expo run:android",
    "legacy:rn:mobile-ios": "expo run:ios",
    "legacy:rn:prebuild": "EXPO_TV=1 expo prebuild --clean",
    "legacy:rn:audit": "npm audit",
    "legacy:rn:clean": "rm -rf node_modules android ios",
    "legacy:rn:lint": "eslint . --debug",
    "legacy:rn:lint-fix": "eslint . --fix",
    "legacy:rn:pretty": "npx prettier *.{ts,tsx} --write",
    "legacy:rn:typecheck": "tsc --noEmit",
    "postinstall": "npx patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/drawer": "^7.4.0",
    "@react-navigation/native": "^7.1.1",
    "@react-navigation/native-stack": "^7.3.2",
    "expo": "^54.0.20",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "~1.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "hls.js": "^1.6.15",
    "lucide-react-native": "^0.563.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "npm:react-native-tvos@0.81-stable",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mpv": "link:./modules/react-native-mpv",
    "react-native-pixel-perfect": "^1.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "~15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native-tvos/config-tv": "^0.1.4",
    "@types/react": "~19.1.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.19.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "resolutions": {
    "tar": ">=7.5.10",
    "minimatch": ">=9.0.7"
  },
  "overrides": {
    "tar": ">=7.5.10",
    "minimatch": ">=9.0.7"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  }
}
